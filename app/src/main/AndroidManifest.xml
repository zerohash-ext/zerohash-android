<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Secure defaults.
        usesCleartextTraffic="false" – prevents HTTP traffic interception.
        allowBackup="false"          – prevents data extraction via adb backup.
        Integrators: do NOT change these to "true" in production applications.
        (Local emulator TLS interception is handled by the debug-only
        network-security overlay in app/src/debug — see DO_NOT_COMMIT.md.)
    -->
    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:theme="@style/Theme.ZerohashDemo"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Demo-only (TEST INFRA): override the SDK's WebViewActivity title so
            the bar shows which Zerohash SDK build is loaded. The label string is
            generated by app/build.gradle.kts from the same `useJitpack` switch
            that selects the dependency.
        -->
        <activity
            android:name="com.zerohash.sdk.ui.WebViewActivity"
            android:label="@string/zerohash_sdk_webview_label"
            tools:replace="android:label" />

    </application>

</manifest>
